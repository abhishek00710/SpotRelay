rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isActiveLifecycleStatus(status) {
      return status == 'posted' || status == 'claimed' || status == 'arriving';
    }

    function isSpotDocument(data) {
      return data.keys().hasAll(['createdBy', 'latitude', 'longitude', 'createdAt', 'leavingAt', 'status']) &&
        data.keys().hasOnly(['createdBy', 'claimedBy', 'latitude', 'longitude', 'createdAt', 'leavingAt', 'cleanupAt', 'status']) &&
        data.createdBy is string &&
        data.latitude is number &&
        data.longitude is number &&
        data.createdAt is timestamp &&
        data.leavingAt is timestamp &&
        (!data.keys().hasAny(['cleanupAt']) || data.cleanupAt is timestamp) &&
        data.status is string;
    }

    function hasNoClaimant(data) {
      return !data.keys().hasAny(['claimedBy']);
    }

    function hasSameClaimant(before, after) {
      return (hasNoClaimant(before) && hasNoClaimant(after)) ||
        (!hasNoClaimant(before) && !hasNoClaimant(after) && before.claimedBy == after.claimedBy);
    }

    function hasValidLocation(data) {
      return data.latitude >= -90 && data.latitude <= 90 &&
        data.longitude >= -180 && data.longitude <= 180;
    }

    function immutableSpotFieldsArePreserved() {
      return request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.latitude == resource.data.latitude &&
        request.resource.data.longitude == resource.data.longitude &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.leavingAt == resource.data.leavingAt;
    }

    function hasValidCleanupAt(data) {
      return data.keys().hasAny(['cleanupAt']) &&
        data.cleanupAt is timestamp &&
        data.cleanupAt > data.createdAt;
    }

    function cleanupFieldIsPreserved() {
      return (!resource.data.keys().hasAny(['cleanupAt']) &&
          !request.resource.data.keys().hasAny(['cleanupAt'])) ||
        (resource.data.keys().hasAny(['cleanupAt']) &&
          request.resource.data.keys().hasAny(['cleanupAt']) &&
          request.resource.data.cleanupAt == resource.data.cleanupAt);
    }

    function changedSpotFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isCreateFromOwner() {
      return isSpotDocument(request.resource.data) &&
        request.resource.data.createdBy == request.auth.uid &&
        hasNoClaimant(request.resource.data) &&
        request.resource.data.status == 'posted' &&
        request.resource.data.leavingAt > request.resource.data.createdAt &&
        hasValidCleanupAt(request.resource.data) &&
        hasValidLocation(request.resource.data);
    }

    function isClaimTransition() {
      return resource.data.status == 'posted' &&
        request.resource.data.status == 'claimed' &&
        hasNoClaimant(resource.data) &&
        !hasNoClaimant(request.resource.data) &&
        request.resource.data.claimedBy == request.auth.uid &&
        request.auth.uid != resource.data.createdBy &&
        changedSpotFields().hasOnly(['claimedBy', 'status']) &&
        cleanupFieldIsPreserved() &&
        immutableSpotFieldsArePreserved();
    }

    function isArrivalTransition() {
      return resource.data.status == 'claimed' &&
        request.resource.data.status == 'arriving' &&
        !hasNoClaimant(resource.data) &&
        request.auth.uid == resource.data.claimedBy &&
        hasSameClaimant(resource.data, request.resource.data) &&
        changedSpotFields().hasOnly(['status']) &&
        cleanupFieldIsPreserved() &&
        immutableSpotFieldsArePreserved();
    }

    function isCancelTransition() {
      return isActiveLifecycleStatus(resource.data.status) &&
        request.resource.data.status == 'cancelled' &&
        (request.auth.uid == resource.data.createdBy ||
          (!hasNoClaimant(resource.data) && request.auth.uid == resource.data.claimedBy)) &&
        hasSameClaimant(resource.data, request.resource.data) &&
        changedSpotFields().hasOnly(['status']) &&
        cleanupFieldIsPreserved() &&
        immutableSpotFieldsArePreserved();
    }

    function isClaimReleaseTransition() {
      return (resource.data.status == 'claimed' || resource.data.status == 'arriving') &&
        !hasNoClaimant(resource.data) &&
        request.auth.uid == resource.data.claimedBy &&
        request.resource.data.status == 'posted' &&
        hasNoClaimant(request.resource.data) &&
        changedSpotFields().hasOnly(['claimedBy', 'status']) &&
        cleanupFieldIsPreserved() &&
        immutableSpotFieldsArePreserved();
    }

    function isCompleteTransition() {
      return isActiveLifecycleStatus(resource.data.status) &&
        request.resource.data.status == 'completed' &&
        (request.auth.uid == resource.data.createdBy ||
          (!hasNoClaimant(resource.data) && request.auth.uid == resource.data.claimedBy)) &&
        hasSameClaimant(resource.data, request.resource.data) &&
        changedSpotFields().hasOnly(['status']) &&
        cleanupFieldIsPreserved() &&
        immutableSpotFieldsArePreserved();
    }

    function isExpiryTransition() {
      return isActiveLifecycleStatus(resource.data.status) &&
        request.resource.data.status == 'expired' &&
        request.time >= resource.data.leavingAt &&
        hasSameClaimant(resource.data, request.resource.data) &&
        changedSpotFields().hasOnly(['status']) &&
        cleanupFieldIsPreserved() &&
        immutableSpotFieldsArePreserved();
    }

    function isDeviceDocument(data, deviceId) {
      return data.keys().hasAll([
          'installationID',
          'platform',
          'bundleID',
          'fcmToken',
          'apnsToken',
          'authorizationStatus',
          'notificationsAuthorized',
          'createdAt',
          'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'installationID',
          'platform',
          'bundleID',
          'fcmToken',
          'apnsToken',
          'authorizationStatus',
          'notificationsAuthorized',
          'createdAt',
          'updatedAt'
        ]) &&
        data.installationID is string &&
        data.installationID == deviceId &&
        data.platform is string &&
        data.platform == 'ios' &&
        data.bundleID is string &&
        data.fcmToken is string &&
        data.apnsToken is string &&
        data.authorizationStatus is string &&
        data.notificationsAuthorized is bool &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        data.updatedAt >= data.createdAt;
    }

    function isUserProfileDocument(data) {
      return data.keys().hasAll([
          'displayName',
          'joinedAt',
          'successfulHandoffs',
          'successfulShares',
          'noShowCount',
          'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'displayName',
          'avatarBase64',
          'joinedAt',
          'successfulHandoffs',
          'successfulShares',
          'noShowCount',
          'updatedAt'
        ]) &&
        data.displayName is string &&
        (!data.keys().hasAny(['avatarBase64']) || data.avatarBase64 is string) &&
        data.joinedAt is timestamp &&
        data.successfulHandoffs is int &&
        data.successfulShares is int &&
        data.noShowCount is int &&
        data.updatedAt is timestamp &&
        data.updatedAt >= data.joinedAt &&
        data.successfulHandoffs >= 0 &&
        data.successfulShares >= 0 &&
        data.noShowCount >= 0;
    }

    function immutableDeviceFieldsArePreserved() {
      return request.resource.data.installationID == resource.data.installationID &&
        request.resource.data.platform == resource.data.platform &&
        request.resource.data.bundleID == resource.data.bundleID &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    match /spots/{spotId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isCreateFromOwner();
      allow update: if isSignedIn() &&
        isSpotDocument(request.resource.data) &&
        (isClaimTransition() ||
          isClaimReleaseTransition() ||
          isArrivalTransition() ||
          isCancelTransition() ||
          isCompleteTransition() ||
          isExpiryTransition());
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        isUserProfileDocument(request.resource.data);
      allow update: if isSignedIn() &&
        request.auth.uid == userId &&
        isUserProfileDocument(request.resource.data);
      allow delete: if false;
    }

    match /users/{userId}/devices/{deviceId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        isDeviceDocument(request.resource.data, deviceId);
      allow update: if isSignedIn() &&
        request.auth.uid == userId &&
        isDeviceDocument(request.resource.data, deviceId) &&
        immutableDeviceFieldsArePreserved();
      allow delete: if false;
    }
  }
}
